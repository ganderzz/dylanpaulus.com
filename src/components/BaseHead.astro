---
import "@styles/main.css";

export interface PostMeta {
  title: string;
  description?: string;
  excerpt?: string;
  date: string;
  heroImage?: string;
  tags?: string[];
  wordCount?: number;
}

export interface Props {
  title: string;
  description: string;
  post?: PostMeta;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, post } = Astro.props;

const isPost = !!post || /^\/posts\//i.test(Astro.url.pathname);
const isHome = Astro.url.pathname === "/";

const cardPath = /posts\/(.+?)/i.exec(Astro.url.pathname)
  ? `${canonicalURL}card.png`
  : `${Astro.site}card.png`;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://dylanpaulus.com";

// Person schema — reused as author on posts and standalone on homepage
const person = {
  "@type": "Person",
  "@id": `${siteUrl}/#person`,
  name: "Dylan Paulus",
  url: siteUrl,
  jobTitle: "Staff Fullstack Software Engineer",
  sameAs: [
    "https://github.com/ganderzz",
    "https://www.linkedin.com/in/dylanpaulus/",
    "https://twitter.com/DylanPaulus",
    "https://dev.to/ganderzz",
  ],
};

// Breadcrumb — built from URL segments
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  { name: "Home", item: `${siteUrl}/` },
  ...pathSegments.map((seg, i) => ({
    name: seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, " "),
    item: `${siteUrl}/${pathSegments.slice(0, i + 1).join("/")}/`,
  })),
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.item,
  })),
};

// Article schema for posts
const articleSchema = post
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: post.title,
      description: post.description ?? post.excerpt ?? description,
      image: post.heroImage
        ? new URL(post.heroImage, Astro.site).toString()
        : cardPath,
      datePublished: new Date(post.date).toISOString(),
      dateModified: new Date(post.date).toISOString(),
      author: person,
      publisher: person,
      keywords: post.tags?.join(", "),
      articleSection: post.tags?.[0],
      ...(post.wordCount ? { wordCount: post.wordCount } : {}),
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalURL.toString(),
      },
      url: canonicalURL.toString(),
      inLanguage: "en-US",
    }
  : null;

// Website / Person schema for non-post pages
const websiteSchema = !post
  ? {
      "@context": "https://schema.org",
      "@graph": [
        person,
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          url: siteUrl,
          name: "Dylan Paulus",
          description:
            "Articles on PostgreSQL, SQL, TypeScript, React, and full-stack engineering.",
          publisher: { "@id": `${siteUrl}/#person` },
          inLanguage: "en-US",
        },
      ],
    }
  : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta http-equiv="x-ua-compatible" content="ie=edge" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" href="/favicon.svg" />
<meta name="robots" content="index, follow" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} data-pagefind-meta="url[href]" />

<link
  rel="alternate"
  type="application/rss+xml"
  title="Dylan Paulus' Blog"
  href={new URL("rss.xml", Astro.site)}
/>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="author" content="Dylan Paulus" />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={isPost ? "article" : "website"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={cardPath} />
<meta property="og:site_name" content="Dylan Paulus" />
<meta property="og:locale" content="en_US" />
{
  post && (
    <>
      <meta property="article:author" content="Dylan Paulus" />
      <meta
        property="article:published_time"
        content={new Date(post.date).toISOString()}
      />
      {post.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={cardPath} />
<meta name="twitter:creator" content="@DylanPaulus" />
<meta name="twitter:site" content="@DylanPaulus" />

<!-- Fonts -->
<link rel="preconnect" href="https://rsms.me/" />
<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

<!-- Structured data (schema.org) -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbSchema)}
/>
{
  articleSchema && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
  )
}
{
  websiteSchema && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  )
}
