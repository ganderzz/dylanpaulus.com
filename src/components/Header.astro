---
import Logo from "./Logo.astro";
import { ThemeToggle } from "./ThemeToggle";

const links = [
  { href: "/", label: "Home" },
  { href: "/posts", label: "Posts" },
  { href: "/courses", label: "Course" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="kb-header relative">
  <div class="brand-halo" aria-hidden="true"></div>

  <div
    class="relative z-10 px-6 sm:px-10 lg:px-14 pt-6 pb-4 sm:pt-7 sm:pb-2 max-w-screen-2xl mx-auto"
    transition:animate="fade">
    <div
      class="flex flex-col gap-4 lg:grid lg:grid-cols-[auto_auto] justify-between lg:items-center lg:gap-5">
      <a
        href="/"
        title="Navigate to home page"
        class="hover:scale-105 transform transition-transform no-underline inline-flex items-center self-start lg:self-center">
        <Logo height={48} />
      </a>

      <nav
        aria-label="Main menu"
        class="kb-nav inline-flex items-center gap-1 p-[5px] rounded-xl border self-start lg:self-center mx-auto"
        style="background: rgba(255,255,255,0.7); border-color: var(--brand-rule); backdrop-filter: blur(6px);">
        {
          links.map(({ href, label }) => {
            const isActive = href === "/" ? currentPath === "/" : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class:list={[
                  "px-4 py-2 rounded-lg text-sm font-medium no-underline transition-colors",
                  isActive
                    ? "bg-[var(--brand-ink)] text-[var(--brand-paper)]"
                    : "text-[var(--brand-ink)] hover:bg-black/5 dark:hover:bg-white/10",
                ]}>
                {label}
              </a>
            );
          })
        }
        <div
          class="ml-1 inline-flex items-center justify-center w-[38px] h-[38px] rounded-lg">
          <ThemeToggle client:only="preact" />
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .kb-header {
    overflow: hidden;
  }
  :global(html[data-theme="dark"]) .kb-nav {
    background: rgba(255, 255, 255, 0.05) !important;
  }
</style>
